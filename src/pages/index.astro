---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Secure Password Generator & Crack Time Estimator" description="Generate strong random passwords and estimate brute-force crack times.">
  <style>.strength-bar{transition:width .4s ease,background-color .4s ease;}input[type="range"]::-webkit-slider-runnable-track{height:8px;border-radius:9999px;background:linear-gradient(to right,#ddd6fe,#8b5cf6);}input[type="range"]::-moz-range-track{height:8px;border-radius:9999px;background:linear-gradient(to right,#ddd6fe,#8b5cf6);}</style>
  <section class="mb-8"><p class="text-gray-600 leading-relaxed">Generate <strong>secure random passwords</strong> and see <strong>brute-force crack time</strong>. Adjust length and character types.</p></section>
  <section id="calculator">
    <div class="bg-gray-50 rounded-lg p-4 border border-gray-200 mb-6"><label for="length" class="block text-sm font-semibold text-gray-700 mb-2">Password Length</label><input type="range" id="length" min="4" max="64" step="1" value="16" class="w-full h-2 rounded-lg appearance-none cursor-pointer mt-2 accent-purple-600"/><div class="flex justify-between mt-1"><span class="text-xs text-gray-400">4</span><span class="text-lg font-bold text-purple-600" id="lengthDisplay">16 characters</span><span class="text-xs text-gray-400">64</span></div></div>
    <div class="grid grid-cols-2 gap-3 mb-6">
      <label class="flex items-center gap-2 bg-gray-50 rounded-lg p-3 border border-gray-200 cursor-pointer"><input type="checkbox" id="chkUpper" checked class="w-4 h-4 accent-purple-600"/><span class="text-sm">Uppercase (A-Z)</span></label>
      <label class="flex items-center gap-2 bg-gray-50 rounded-lg p-3 border border-gray-200 cursor-pointer"><input type="checkbox" id="chkLower" checked class="w-4 h-4 accent-purple-600"/><span class="text-sm">Lowercase (a-z)</span></label>
      <label class="flex items-center gap-2 bg-gray-50 rounded-lg p-3 border border-gray-200 cursor-pointer"><input type="checkbox" id="chkDigits" checked class="w-4 h-4 accent-purple-600"/><span class="text-sm">Digits (0-9)</span></label>
      <label class="flex items-center gap-2 bg-gray-50 rounded-lg p-3 border border-gray-200 cursor-pointer"><input type="checkbox" id="chkSymbols" checked class="w-4 h-4 accent-purple-600"/><span class="text-sm">Symbols (!@#$)</span></label>
    </div>
    <button id="generateBtn" class="w-full bg-purple-600 hover:bg-purple-700 text-white font-semibold py-3 rounded-lg mb-6">Generate Password</button>
    <div id="resultArea" class="hidden">
      <div class="bg-purple-50 rounded-xl p-5 mb-4 border border-purple-200"><div class="flex items-center justify-between mb-3"><p class="text-sm font-semibold text-purple-800">Your Password</p><button id="copyBtn" class="text-xs bg-purple-600 text-white px-3 py-1 rounded-full hover:bg-purple-700">Copy</button></div><p id="passwordDisplay" class="text-xl font-mono text-purple-900 break-all select-all"></p></div>
      <div class="bg-gray-50 rounded-lg p-4 mb-4 border border-gray-200"><p class="text-sm font-semibold text-gray-700 mb-2">Strength</p><div class="w-full h-3 bg-gray-200 rounded-full overflow-hidden"><div id="strengthBar" class="strength-bar h-full rounded-full" style="width:0%"></div></div><p id="strengthLabel" class="text-sm font-bold mt-1 text-gray-600"></p></div>
      <div class="grid sm:grid-cols-2 gap-4 mb-6"><div class="bg-red-50 rounded-lg p-4 border border-red-200 text-center"><p class="text-xs text-red-600 mb-1">Crack Time (10B/sec)</p><p class="text-xl font-bold text-red-700" id="crackTime">-</p></div><div class="bg-gray-50 rounded-lg p-4 border border-gray-200 text-center"><p class="text-xs text-gray-500 mb-1">Entropy</p><p class="text-xl font-bold text-gray-800" id="entropyBits">- bits</p></div></div>
    </div>
    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 text-sm text-amber-800"><p class="font-semibold mb-1">Security Note</p><p class="text-xs">Passwords generated client-side using crypto.getRandomValues(). Nothing transmitted.</p></div>
  </section>
  <section class="mt-10 mb-8"><h2 class="text-2xl font-bold text-gray-800 mb-4">Password Strength Guide</h2><div class="overflow-x-auto"><table class="w-full text-sm text-left border border-gray-200 rounded-lg"><thead class="bg-purple-50 text-purple-800"><tr><th class="px-4 py-3">Length</th><th class="px-4 py-3 text-center">Crack Time</th><th class="px-4 py-3 text-center">Rating</th></tr></thead><tbody class="divide-y divide-gray-100"><tr class="hover:bg-gray-50"><td class="px-4 py-3">8 chars</td><td class="px-4 py-3 text-center">~2 hrs</td><td class="px-4 py-3 text-center text-red-600">Weak</td></tr><tr class="hover:bg-gray-50"><td class="px-4 py-3">12 chars</td><td class="px-4 py-3 text-center">~34 years</td><td class="px-4 py-3 text-center text-yellow-600">Fair</td></tr><tr class="hover:bg-gray-50"><td class="px-4 py-3">16 chars</td><td class="px-4 py-3 text-center">~292M years</td><td class="px-4 py-3 text-center text-green-600">Strong</td></tr><tr class="hover:bg-gray-50"><td class="px-4 py-3">20 chars</td><td class="px-4 py-3 text-center">~23 decillion years</td><td class="px-4 py-3 text-center text-green-700">Very Strong</td></tr><tr class="hover:bg-gray-50"><td class="px-4 py-3">24+ chars</td><td class="px-4 py-3 text-center">Beyond universe age</td><td class="px-4 py-3 text-center text-purple-600">Unbreakable</td></tr></tbody></table></div></section>
  <section id="faq" class="mb-8"><h2 class="text-2xl font-bold text-gray-800 mb-6">FAQ</h2><div class="space-y-4"><details class="group bg-gray-50 rounded-lg border border-gray-200 open:bg-white open:shadow-sm"><summary class="cursor-pointer px-4 py-3 font-semibold text-sm">How long should a password be?</summary><div class="px-4 pb-4 text-sm text-gray-600"><p>At least <strong>12 characters</strong> with mixed types. 16+ is ideal.</p></div></details><details class="group bg-gray-50 rounded-lg border border-gray-200 open:bg-white open:shadow-sm"><summary class="cursor-pointer px-4 py-3 font-semibold text-sm">What makes it strong?</summary><div class="px-4 pb-4 text-sm text-gray-600"><p>Length, randomness, variety of character types.</p></div></details><details class="group bg-gray-50 rounded-lg border border-gray-200 open:bg-white open:shadow-sm"><summary class="cursor-pointer px-4 py-3 font-semibold text-sm">Is this safe?</summary><div class="px-4 pb-4 text-sm text-gray-600"><p>Yes. In-browser using <strong>crypto.getRandomValues()</strong>.</p></div></details><details class="group bg-gray-50 rounded-lg border border-gray-200 open:bg-white open:shadow-sm"><summary class="cursor-pointer px-4 py-3 font-semibold text-sm">How fast can hackers crack?</summary><div class="px-4 pb-4 text-sm text-gray-600"><p><strong>10-100 billion guesses/sec</strong> with modern GPUs.</p></div></details><details class="group bg-gray-50 rounded-lg border border-gray-200 open:bg-white open:shadow-sm"><summary class="cursor-pointer px-4 py-3 font-semibold text-sm">Use password manager?</summary><div class="px-4 pb-4 text-sm text-gray-600"><p><strong>Yes.</strong> Unique passwords per account.</p></div></details></div></section>
  <script type="application/ld+json" is:inline>{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"How long?","acceptedAnswer":{"@type":"Answer","text":"12+ chars. 16+ ideal."}},{"@type":"Question","name":"What makes it strong?","acceptedAnswer":{"@type":"Answer","text":"Length, randomness, variety."}},{"@type":"Question","name":"Safe?","acceptedAnswer":{"@type":"Answer","text":"Yes. In-browser crypto."}},{"@type":"Question","name":"Crack speed?","acceptedAnswer":{"@type":"Answer","text":"10-100B guesses/sec."}},{"@type":"Question","name":"Password manager?","acceptedAnswer":{"@type":"Answer","text":"Yes. Unique per account."}}]}</script>
  <script is:inline define:vars={{}}>
    (function(){var U="ABCDEFGHIJKLMNOPQRSTUVWXYZ",L="abcdefghijklmnopqrstuvwxyz",D="0123456789",S="!@#$%^&*()_+-=[]{}|;:,.<>?";var ls=document.getElementById("length"),ld=document.getElementById("lengthDisplay"),btn=document.getElementById("generateBtn"),cp=document.getElementById("copyBtn");function cs(){var c="";if(document.getElementById("chkUpper").checked)c+=U;if(document.getElementById("chkLower").checked)c+=L;if(document.getElementById("chkDigits").checked)c+=D;if(document.getElementById("chkSymbols").checked)c+=S;return c;}function gp(l,c){var a=new Uint32Array(l);crypto.getRandomValues(a);var p="";for(var i=0;i<l;i++)p+=c[a[i]%c.length];return p;}function ce(l,s){return Math.round(l*Math.log2(s));}function ft(s){if(s<1)return"Instant";if(s<60)return Math.round(s)+" sec";if(s<3600)return Math.round(s/60)+" min";if(s<86400)return Math.round(s/3600)+" hrs";if(s<86400*365)return Math.round(s/86400)+" days";if(s<86400*365*1000)return Math.round(s/(86400*365))+" years";if(s<86400*365*1e6)return(s/(86400*365*1000)).toFixed(1)+"K years";if(s<86400*365*1e9)return(s/(86400*365*1e6)).toFixed(1)+"M years";if(s<86400*365*1e12)return(s/(86400*365*1e9)).toFixed(1)+"B years";if(s<86400*365*1e15)return(s/(86400*365*1e12)).toFixed(1)+"T years";return"Beyond age of universe";}function gs(e){if(e<28)return{l:"Very Weak",c:"#dc2626",p:10};if(e<36)return{l:"Weak",c:"#ea580c",p:25};if(e<60)return{l:"Fair",c:"#ca8a04",p:50};if(e<80)return{l:"Strong",c:"#16a34a",p:75};if(e<128)return{l:"Very Strong",c:"#059669",p:90};return{l:"Unbreakable",c:"#7c3aed",p:100};}function gen(){var c=cs();if(!c.length)return;var l=parseInt(ls.value);ld.textContent=l+" characters";var pw=gp(l,c),en=ce(l,c.length),ct=Math.pow(2,en)/1e10,st=gs(en);document.getElementById("resultArea").classList.remove("hidden");document.getElementById("passwordDisplay").textContent=pw;document.getElementById("entropyBits").textContent=en+" bits";document.getElementById("crackTime").textContent=ft(ct);var b=document.getElementById("strengthBar");b.style.width=st.p+"%";b.style.backgroundColor=st.c;document.getElementById("strengthLabel").textContent=st.l;document.getElementById("strengthLabel").style.color=st.c;}ls.addEventListener("input",function(){ld.textContent=this.value+" characters";});btn.addEventListener("click",gen);cp.addEventListener("click",function(){navigator.clipboard.writeText(document.getElementById("passwordDisplay").textContent).then(function(){cp.textContent="Copied!";setTimeout(function(){cp.textContent="Copy";},2000);});});gen();})();
  </script>
</Layout>
